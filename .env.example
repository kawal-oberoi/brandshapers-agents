# Copy this file to ".env" and replace the placeholder values with your real
# tokens. Do NOT commit the real .env file — it is ignored by git.

# Slack "Bot User OAuth Token" — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack "App-Level Token" with the connections:write scope — starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Anthropic API key — starts with sk-ant-
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Apollo.io API key — found in Apollo under Settings → Integrations → API.
# Used by Agent 2 (the Sourcer) for People Search (free) and Enrichment (~1 credit).
APOLLO_API_KEY=your-apollo-api-key-here

# --- Agent 2 (Sourcer) settings — all optional, sensible defaults shown ---
# Most enrichment credits Agent 2 may spend per calendar month (protects credits).
APOLLO_MONTHLY_CAP=70
# Slack channel where sourcing summaries are posted.
OUTREACH_CHANNEL=#outreach-control
# Weekly auto-sourcing schedule (set ENABLED to false to turn it off).
SOURCER_SCHEDULE_ENABLED=true
SOURCER_SCHEDULE_DAY=mon
SOURCER_SCHEDULE_HOUR=9
SOURCER_SCHEDULE_MINUTE=0
SOURCER_SCHEDULE_TZ=Asia/Kolkata
SOURCER_SCHEDULE_MAX_ENRICH=10

# The ID of the Google Sheet used as Agent 1's source of truth.
# (It's the long string in the sheet's URL between /d/ and /edit.)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Google service account credentials.
#  - Locally: leave this blank and keep the google-credentials.json file in the
#    project folder. The bot reads the file automatically.
#  - On Railway: paste the ENTIRE contents of google-credentials.json as the
#    value of this variable. The bot prefers this env var when it is set.
GOOGLE_CREDENTIALS_JSON=
